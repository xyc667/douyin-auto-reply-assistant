# ============================================
# AI 智能回复系统配置（示例）
# ============================================
# 复制本文件为 config_ai.env 后填入你自己的值

AI_PROVIDER=anthropic
AI_MODEL=MiniMax-M2.7

ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=

MIN_REPLY_DELAY=8
MAX_REPLY_DELAY=20
AUTO_REPLY_ENABLED=true
KNOWLEDGE_FIRST=true
AI_FALLBACK=true

LOG_FILE=datas/reply_log.txt
LOG_KEEP_DAYS=30
BLACKLIST_FILE=datas/blacklist.txt
MAX_RETRY=3
RETRY_DELAY=10
MAX_CONCURRENT=5

SYSTEM_PROMPT=你是一个真实的朋友在微信聊天。简短回复5-15字，用语气词（嗯嗯、哈哈、好的、稍等），像朋友聊天不要客服语气，不确定就说我看看或稍等哈，不要正式称呼。
