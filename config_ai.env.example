# ============================================
# AI 智能回复系统配置（示例）
# ============================================
# ⚠️ 此文件仅作为模板，请勿提交真实 API Key
# 复制本文件为 config_ai.env 后填入你自己的值

# ============================================
# AI 服务商配置
# 支持：anthropic / openai / 自定义 OpenAI 兼容接口
# ============================================
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-sonnet-latest

# Anthropic 兼容接口示例（可指向任何 OpenAI 兼容服务）
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# 若使用 OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-openai-key

# ============================================
# 回复行为
# ============================================
# 真人化：随机延迟区间（秒）
MIN_REPLY_DELAY=8
MAX_REPLY_DELAY=20

# 是否启用自动回复
AUTO_REPLY_ENABLED=true

# 知识库优先：true=先查知识库；false=直接调用 AI
KNOWLEDGE_FIRST=true

# AI 降级：true=知识库未命中时调用 AI；false=不回复
AI_FALLBACK=false

# ============================================
# 系统设置
# ============================================
LOG_FILE=datas/reply_log.txt
LOG_KEEP_DAYS=30
BLACKLIST_FILE=datas/blacklist.txt
MAX_RETRY=3
RETRY_DELAY=10
MAX_CONCURRENT=5

# 真人风格系统提示词（单行，避免 dotenv 解析失败）
SYSTEM_PROMPT=你是一个真实的朋友在微信聊天。简短回复5-15字，用语气词（嗯嗯、哈哈、好的、稍等），像朋友聊天不要客服语气，不确定就说我看看或稍等哈，不要正式称呼。